  "item": [
    {
      "name": "TC001_Valid-Endpoint",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//=========================\r",
              "//I&M QA Assessment - API\r",
              "//Endpoint: https://randomuser.me/api/\r",
              "// 8 test cases\r",
              "// author\r",
              "// date\r",
              "\r",
              "//const BASE_URL = \"https://randomuser.me/api/\";\r",
              "//TC001: Valid Endpoint\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"status code is 200\", function(){\r",
              "    //pm.response.to.have.status(200);\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Returns 1 user\", function(){\r",
              "    pm.expect(jsonData.results.length).to.eql(1);\r",
              "});\r",
              "\r",
              "pm.test(\"Email contains @symbol\", function(){\r",
              "    pm.expect(jsonData.results[0].email).to.include('@');\r",
              "});\r",
              "pm.test(\"Phone number contains digits\", function(){\r",
              "    pm.expect(jsonData.results[0].phone).to.match(/\\d+/);\r",
              "});\r",
              "pm.test(\"Name field exist\", function(){\r",
              "    pm.expect(jsonData.results[0].name).to.have.property('first');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://randomuser.me/api/",
          "protocol": "https",
          "host": [
            "randomuser",
            "me"
          ],
          "path": [
            "api",
            ""
          ]
        }
      },
      "response": []
    },
